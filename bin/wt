#!/usr/bin/env bash
# wt — agent-agnostic git worktree provisioning.
#
# Wraps `git worktree add` so symlink mirroring and per-repo harness setup
# fire deterministically on every fresh worktree, instead of depending on
# agent skill prose. Tool-agnostic: a Codex skill and a Claude skill both
# delegate to this same primitive.
#
# Conventions:
#   - Worktrees live at  <main_repo>/.worktrees/<slug>/
#   - Branch name        = slug verbatim (no auto-prefix; pass `feat/x` if you want it)
#   - Cut from           origin/dev  (refreshed via fetch before creation)
#   - Symlink hook fires explicitly after creation (modern git's reset-hard
#     populate path skips post-checkout)
#   - .harness/setup     runs after symlinks if present + executable
#
# Designed for solo + small-team use with up-to-100 parallel agents. The
# port allocator (.harness/setup) is per-repo; this script doesn't know
# about ports.

set -euo pipefail

POST_CHECKOUT_HOOK="$HOME/.git-hooks/post-checkout"

usage() {
  cat <<'EOF'
Usage: wt <command> [args]

Commands:
  new <slug>              Create .worktrees/<slug>/ off origin/dev with symlinks + .harness/setup
  rm  <slug>              Remove worktree and delete the matching branch
  ls                      List active worktrees (delegates to `git worktree list`)
  path <slug>             Print absolute path of a named worktree
  ports                   Show the port map for the current worktree (or main repo)
  reconcile <slug|--all>  Re-run symlink hook + .harness/setup against existing worktree(s)
  --help                  Show this message

Layout: <main_repo>/.worktrees/<slug>/    Branch: <slug> verbatim
EOF
}

die() { echo "wt: $*" >&2; exit 1; }

main_repo() {
  # git-common-dir is relative for a regular checkout, absolute for a linked
  # worktree. Resolve via cd + pwd -P so we end up at the canonical main repo.
  local common
  common=$(git rev-parse --git-common-dir 2>/dev/null) || return 1
  (cd "$common/.." && pwd -P)
}

ensure_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repo"
}

validate_slug() {
  local slug="${1-}"
  [ -n "$slug" ] || die "slug is required"
  git check-ref-format --branch "$slug" >/dev/null 2>&1 \
    || die "invalid slug '$slug' (not a valid git branch name)"
}

run_hook_then_setup() {
  local wt_path="$1"
  if [ -x "$POST_CHECKOUT_HOOK" ]; then
    (cd "$wt_path" && "$POST_CHECKOUT_HOOK" HEAD HEAD 1) \
      || echo "wt: post-checkout hook exited non-zero in $wt_path (non-fatal)" >&2
  else
    echo "wt: $POST_CHECKOUT_HOOK not executable; skipping symlink mirror" >&2
  fi
  if [ -x "$wt_path/.harness/setup" ]; then
    (cd "$wt_path" && ./.harness/setup) \
      || echo "wt: .harness/setup exited non-zero in $wt_path (non-fatal)" >&2
  fi
}

cmd_new() {
  validate_slug "${1-}"
  local slug="$1"
  local repo
  repo=$(main_repo) || die "could not resolve main repo"
  local wt_path="$repo/.worktrees/$slug"

  [ -e "$wt_path" ] && die "$wt_path already exists (use 'wt rm $slug' first)"

  git -C "$repo" fetch origin dev >/dev/null 2>&1 || true
  # --no-track: branch is based on origin/dev but does NOT track it as upstream.
  # Default git behavior would set upstream=origin/dev so `git push` writes to
  # dev, which is dangerous. The user pushes to origin/<slug> when the branch
  # is ready (typically via /ship), not to dev directly.
  git -C "$repo" worktree add --no-track -b "$slug" "$wt_path" origin/dev

  run_hook_then_setup "$wt_path"
  echo "$wt_path"
}

cmd_rm() {
  validate_slug "${1-}"
  local slug="$1"
  local repo
  repo=$(main_repo) || die "could not resolve main repo"

  # Resolve worktree path by basename match against the live registry —
  # handles both .worktrees/<slug> (current layout) and legacy
  # .claude/worktrees/<slug> without hardcoding either, and surfaces a
  # real error when nothing matches instead of pretending success.
  local wt_path=""
  local p
  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        p="${line#worktree }"
        if [ "$(basename "$p")" = "$slug" ]; then
          wt_path="$p"
          break
        fi
        ;;
    esac
  done < <(git -C "$repo" worktree list --porcelain)

  # Read the worktree's actual HEAD branch BEFORE removing it. The
  # branch may differ from the slug if someone created a new branch
  # inside the worktree mid-flight (e.g. for a hotfix PR) — relying
  # on slug==branch silently orphans those refs.
  local active_branch=""
  if [ -n "$wt_path" ]; then
    active_branch=$(git -C "$wt_path" branch --show-current 2>/dev/null || true)

    # Loud on failure. Silent `|| true` on these three calls is what hid
    # the layout/branch-name bugs and made `wt rm` print success while
    # doing nothing.
    git -C "$repo" worktree remove --force "$wt_path"
    [ -d "$wt_path" ] && rm -rf "$wt_path"
  fi

  # Sweep orphan directories at known layouts. Earlier versions of cmd_rm
  # left these behind when the registry was pruned but the rm -rf targeted
  # the wrong layout. Self-healing on subsequent rm calls.
  local orphans=()
  local candidate
  for candidate in "$repo/.worktrees/$slug" "$repo/.claude/worktrees/$slug"; do
    if [ "$candidate" != "$wt_path" ] && [ -d "$candidate" ]; then
      rm -rf "$candidate"
      orphans+=("$candidate")
    fi
  done

  # Delete branches that lived in this worktree. Try the active HEAD,
  # the slug-named ref, and the legacy feat/<slug> convention — any
  # subset may exist depending on how the worktree was created.
  local deleted=()
  local b
  for b in "$active_branch" "$slug" "feat/$slug"; do
    [ -z "$b" ] && continue
    case " ${deleted[*]-} " in *" $b "*) continue;; esac
    if git -C "$repo" rev-parse --verify "$b" >/dev/null 2>&1; then
      git -C "$repo" branch -D "$b" >/dev/null 2>&1 && deleted+=("$b")
    fi
  done

  if [ -z "$wt_path" ] && [ ${#orphans[@]} -eq 0 ] && [ ${#deleted[@]} -eq 0 ]; then
    die "nothing matched '$slug' — no registered worktree, orphan dir, or local branch"
  fi

  local summary=""
  [ -n "$wt_path" ]          && summary+=" worktree=$wt_path"
  [ ${#orphans[@]} -gt 0 ]   && summary+=" orphan_dirs=[${orphans[*]}]"
  [ ${#deleted[@]} -gt 0 ]   && summary+=" branches=[${deleted[*]}]"
  echo "wt: removed$summary"
}

cmd_ls() {
  local repo
  repo=$(main_repo) || die "could not resolve main repo"
  git -C "$repo" worktree list
}

cmd_path() {
  validate_slug "${1-}"
  local slug="$1"
  local repo
  repo=$(main_repo) || die "could not resolve main repo"
  local wt_path="$repo/.worktrees/$slug"
  [ -d "$wt_path" ] || die "no worktree at $wt_path"
  echo "$wt_path"
}

cmd_ports() {
  local git_dir git_common_dir
  git_dir=$(git rev-parse --git-dir 2>/dev/null) || die "not in a git repo"
  git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null)

  local source_file slug
  if [ "$git_dir" = "$git_common_dir" ]; then
    # In the main repo: no shift; use the base values from dev.env directly.
    local repo
    repo=$(main_repo) || die "could not resolve main repo"
    source_file="$repo/clyzdale/dev.env"
    slug="(main repo, no shift)"
  else
    # In a linked worktree: prefer .env.local (shifted). Fall back to dev.env if
    # setup hasn't run yet.
    local wt_root
    wt_root=$(git rev-parse --show-toplevel)
    if [ -f "$wt_root/clyzdale/.env.local" ]; then
      source_file="$wt_root/clyzdale/.env.local"
    elif [ -f "$wt_root/clyzdale/dev.env" ]; then
      source_file="$wt_root/clyzdale/dev.env"
      echo "wt: no .env.local — run ./.harness/setup to allocate shifted ports" >&2
    else
      die "neither clyzdale/.env.local nor clyzdale/dev.env present in $wt_root"
    fi
    slug=$(basename "$wt_root")
  fi

  set -a
  # shellcheck disable=SC1090
  . "$source_file"
  set +a

  printf "Worktree: %s\n" "$slug"
  printf "Offset:   %s\n" "${PORT_OFFSET:-0}"
  printf "Source:   %s\n\n" "$source_file"
  printf "  %-14s http://localhost:%s\n" "tenancy UI:"      "${DEV_VITE_PORT_TENANCY:-5173}"
  printf "  %-14s http://localhost:%s\n" "admin UI:"        "${DEV_VITE_PORT_ADMIN:-5174}"
  printf "  %-14s http://localhost:%s\n" "workspace UI:"    "${DEV_VITE_PORT_WORKSPACE:-5175}"
  printf "  %-14s http://localhost:%s\n" "agent UI:"        "${DEV_VITE_PORT_AGENT:-5176}"
  echo
  printf "  %-14s http://localhost:%s\n" "tenancy API:"     "${DEV_API_PORT_TENANCY:-8000}"
  printf "  %-14s http://localhost:%s\n" "admin API:"       "${DEV_API_PORT_ADMIN:-8001}"
  printf "  %-14s http://localhost:%s\n" "workspace API:"   "${DEV_API_PORT_WORKSPACE:-8002}"
  printf "  %-14s http://localhost:%s\n" "agent API:"       "${DEV_API_PORT_AGENT:-8003}"
  printf "  %-14s %s\n" "agent (cross):"  "${TENANT_AGENT_URL_OVERRIDE:-http://localhost:8003}"
}

cmd_reconcile() {
  local target="${1-}"
  local repo
  repo=$(main_repo) || die "could not resolve main repo"
  local paths=()

  if [ -z "$target" ] || [ "$target" = "--all" ]; then
    while IFS= read -r line; do
      local p
      p=$(printf '%s' "$line" | awk '{print $1}')
      [ "$p" = "$repo" ] && continue
      paths+=("$p")
    done < <(git -C "$repo" worktree list)
  else
    validate_slug "$target"
    paths+=("$repo/.worktrees/$target")
  fi

  [ ${#paths[@]} -eq 0 ] && { echo "wt: no worktrees to reconcile"; return 0; }

  for p in "${paths[@]}"; do
    [ -d "$p" ] || { echo "wt: missing $p, skip" >&2; continue; }
    echo "wt: reconciling $p"
    run_hook_then_setup "$p"
  done
}

[ $# -eq 0 ] && { usage; exit 1; }

case "$1" in
  new)        shift; ensure_repo; cmd_new "$@" ;;
  rm|remove)  shift; ensure_repo; cmd_rm "$@" ;;
  ls|list)    shift; ensure_repo; cmd_ls ;;
  path)       shift; ensure_repo; cmd_path "$@" ;;
  ports)      shift; ensure_repo; cmd_ports ;;
  reconcile)  shift; ensure_repo; cmd_reconcile "${1-}" ;;
  --help|-h|help) usage ;;
  *)          echo "wt: unknown command '$1'" >&2; usage; exit 1 ;;
esac
